---
interface Props {
  command: string;
}
const { command } = Astro.props;
---

<div class="install-block">
  <pre><code>{command}</code></pre>
  <button
    type="button"
    class="install-copy"
    data-copy={command}
    aria-label="Copy install command to clipboard"
  >
    <span class="install-copy-text">Copy</span>
  </button>
</div>

<style>
  .install-block {
    position: relative;
    max-width: 100%;
  }
  .install-block pre {
    margin: 0;
    padding-right: 5rem;
    font-size: 0.95rem;
  }
  .install-copy {
    position: absolute;
    top: 0.6rem;
    right: 0.6rem;
    background: var(--surface-2);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.35rem 0.75rem;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 120ms ease;
  }
  .install-copy:hover { background: var(--border); }
  .install-copy.copied { background: var(--accent); color: #0a0d12; border-color: var(--accent); }
</style>

<script>
  for (const btn of document.querySelectorAll<HTMLButtonElement>(".install-copy")) {
    btn.addEventListener("click", async () => {
      const cmd = btn.getAttribute("data-copy") ?? "";
      const text = btn.querySelector<HTMLSpanElement>(".install-copy-text");
      try {
        await navigator.clipboard.writeText(cmd);
        if (text) {
          const orig = text.textContent;
          text.textContent = "Copied!";
          btn.classList.add("copied");
          setTimeout(() => {
            text.textContent = orig;
            btn.classList.remove("copied");
          }, 1500);
        }
      } catch {
        // clipboard blocked; do nothing
      }
    });
  }
</script>
