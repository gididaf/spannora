---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Page not found — spannora";
const description =
  "The page you're looking for doesn't exist on spannora.dev. Try the homepage, the docs, or the install guide.";
---

<BaseLayout title={title} description={description} noindex={true}>
  <section>
    <div class="container">
      <div class="not-found">
        <p class="status">404</p>
        <h1>Page not found</h1>
        <p class="lead">
          The page you're looking for doesn't exist — or it moved. Try one of
          these instead.
        </p>
        <ul class="links">
          <li><a href="/">Home</a></li>
          <li><a href="/docs/">Docs</a></li>
          <li><a href="/docs/install/">Install spannora</a></li>
        </ul>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .not-found {
    max-width: 40em;
    margin: 2rem auto;
    text-align: center;
  }
  .status {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text-muted);
    letter-spacing: 0.15em;
    margin: 0 0 0.5rem;
  }
  .not-found h1 {
    margin-bottom: 0.75rem;
  }
  .links {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }
  .links a {
    display: inline-block;
    padding: 0.625rem 1.125rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    background: var(--surface);
    color: var(--text);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .links a:hover {
    background: var(--surface-2);
    text-decoration: none;
  }
</style>
