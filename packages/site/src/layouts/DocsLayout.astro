---
import BaseLayout from "./BaseLayout.astro";

interface Frontmatter {
  title: string;
  description: string;
  breadcrumb?: string;
  datePublished?: string;
  dateModified?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

interface Props {
  frontmatter: Frontmatter;
}

const { frontmatter } = Astro.props;
const SITE_URL = "https://spannora.dev";
const canonical = new URL(Astro.url.pathname, SITE_URL).href;

const breadcrumbItems: Record<string, unknown>[] = [
  { "@type": "ListItem", position: 1, name: "Home", item: SITE_URL + "/" },
  { "@type": "ListItem", position: 2, name: "Docs", item: SITE_URL + "/docs/" },
];
if (frontmatter.breadcrumb) {
  breadcrumbItems.push({
    "@type": "ListItem",
    position: 3,
    name: frontmatter.breadcrumb,
    item: canonical,
  });
}

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: breadcrumbItems,
};

const ldBlocks: Record<string, unknown>[] = [breadcrumbLd];

if (frontmatter.datePublished) {
  ldBlocks.push({
    "@context": "https://schema.org",
    "@type": "TechArticle",
    headline: frontmatter.title,
    description: frontmatter.description,
    mainEntityOfPage: canonical,
    url: canonical,
    datePublished: frontmatter.datePublished,
    dateModified: frontmatter.dateModified ?? frontmatter.datePublished,
    author: { "@type": "Organization", name: "spannora", url: SITE_URL },
    publisher: { "@type": "Organization", name: "spannora", url: SITE_URL },
  });
}

if (frontmatter.jsonLd) {
  const extras = Array.isArray(frontmatter.jsonLd) ? frontmatter.jsonLd : [frontmatter.jsonLd];
  for (const block of extras) ldBlocks.push(block);
}
---

<BaseLayout
  title={frontmatter.title}
  description={frontmatter.description}
  jsonLd={ldBlocks}
>
  <article class="container prose docs-article">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <a href="/">Home</a> <span aria-hidden="true">/</span>
      {frontmatter.breadcrumb ? (
        <>
          <a href="/docs/">Docs</a> <span aria-hidden="true">/</span>
          <span>{frontmatter.breadcrumb}</span>
        </>
      ) : (
        <span>Docs</span>
      )}
    </nav>
    <slot />
  </article>
</BaseLayout>

<style>
  .docs-article { padding: 3rem 0 4rem; }
  .breadcrumb {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }
  .breadcrumb a { color: var(--text-muted); }
  .breadcrumb a:hover { color: var(--text); }
  .breadcrumb span[aria-hidden] { margin: 0 0.4rem; }
</style>
